kf     = StratifiedKFold(n_splits=5)
best_rf = RandomForestClassifier(**grid_search.best_params_, class_weight="balanced", random_state=42)
cv_scores = []

for fold, (train_idx, test_idx) in enumerate(kf.split(X, y), 1):
    X_tr, X_te = X.iloc[train_idx], X.iloc[test_idx]
    y_tr, y_te = y.iloc[train_idx], y.iloc[test_idx]

    best_rf.fit(X_tr, y_tr)
    y_pred_cv = best_rf.predict(X_te)
    fold_f1   = f1_score(y_te, y_pred_cv, average='macro')
    cv_scores.append(fold_f1)
    print(f"  Fold {fold} — F1 (macro): {fold_f1:.4f}")

print(f"\nAverage F1 Score (macro) across 5 folds: {np.mean(cv_scores):.4f}")


