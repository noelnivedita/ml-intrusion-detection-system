# =============================================================================
# SECTION 13: IAM — IDENTITY & ACCESS MANAGEMENT LAYER
#
# PURPOSE: Reduce false positives by applying IAM-based trust rules on top
#          of the ML model's raw predictions.
#
# HOW IT WORKS:
#   - Each network flow is assigned an IAM trust score based on source IP,
#     destination port, and protocol — mimicking role/privilege metadata.
#   - Flows from "trusted" identities (internal IPs, known safe ports) that
#     are flagged as attacks by the ML model are re-examined.
#   - If the trust score is HIGH and the model's attack probability is below
#     a set threshold, the flag is downgraded from Attack (1) to Normal (0).
#   - This simulates how a real IAM layer would reduce noisy alerts from
#     legitimate but unusual-looking traffic by authorized users/services.
# =============================================================================

print("\n" + "=" * 50)
print("IAM — IDENTITY & ACCESS MANAGEMENT LAYER")
print("(False Positive Reduction)")
print("=" * 50)

# --- Step 1: Define IAM Trust Rules ---

# Trusted internal source IP prefixes (simulate known/authorized identities)
TRUSTED_IP_PREFIXES = ['192.168.', '10.0.', '172.16.']

# Trusted destination ports (well-known, low-risk services)
TRUSTED_PORTS = [80, 443, 22, 53, 8080, 8443, 3306, 5432]

# Trusted protocols
TRUSTED_PROTOCOLS = ['TCP', 'UDP']

# IAM decision threshold:
# If attack probability < this value AND trust score is HIGH → override to Normal
IAM_PROBABILITY_THRESHOLD = 0.40


def compute_iam_trust_score(row):
    """
    Assigns an IAM trust score (0, 1, or 2) to each network flow.
      2 = HIGH trust   → trusted IP + trusted port
      1 = MEDIUM trust → only one condition met
      0 = LOW trust    → no trusted attributes
    """
    score = 0

    # Check source IP (use 'src_ip' column if it exists, else skip)
    if 'src_ip' in row.index:
        if any(str(row['src_ip']).startswith(prefix) for prefix in TRUSTED_IP_PREFIXES):
            score += 1

    # Check destination port (use 'dst_pt' or 'dst_port' if available)
    dst_port_col = next((c for c in row.index if 'dst' in c and 'pt' in c), None)
    if dst_port_col and int(row[dst_port_col]) in TRUSTED_PORTS:
        score += 1

    return score  # 0 = LOW, 1 = MEDIUM, 2 = HIGH


# --- Step 2: Get Model Probabilities on Test Set ---
# Use the best tuned Random Forest (must support predict_proba)
rf_final = RandomForestClassifier(**grid_search.best_params_, class_weight="balanced", random_state=42)
rf_final.fit(X_train, y_train)

y_prob_attack = rf_final.predict_proba(X_test)[:, 1]   # probability of Attack (class 1)
y_pred_raw    = rf_final.predict(X_test)                # raw ML predictions

# --- Step 3: Compute IAM Trust Scores for Test Set ---
X_test_reset = X_test.reset_index(drop=True)
trust_scores  = X_test_reset.apply(compute_iam_trust_score, axis=1)

print(f"\nIAM Trust Score Distribution:")
print(pd.Series(trust_scores).value_counts().rename({0: 'LOW (0)', 1: 'MEDIUM (1)', 2: 'HIGH (2)'}))

# --- Step 4: Apply IAM Override Logic ---
y_pred_iam = y_pred_raw.copy()

false_positive_candidates = (
    (y_pred_raw == 1) &                            # ML flagged as attack
    (trust_scores == 2) &                          # HIGH IAM trust
    (y_prob_attack < IAM_PROBABILITY_THRESHOLD)    # model not very confident
)

overrides = false_positive_candidates.sum()
y_pred_iam[false_positive_candidates] = 0          # downgrade to Normal

print(f"\nIAM overrides applied (FP reductions): {overrides}")
print(f"  → Flows re-classified from Attack → Normal based on IAM trust rules")

# --- Step 5: Compare Before vs After IAM ---
print("\n--- Performance BEFORE IAM Layer (Raw ML) ---")
print(classification_report(y_test, y_pred_raw, zero_division=0,
                             target_names=["Normal", "Attack"]))

print("--- Performance AFTER IAM Layer (ML + IAM) ---")
print(classification_report(y_test, y_pred_iam, zero_division=0,
                             target_names=["Normal", "Attack"]))

# Precision comparison (key metric for FP reduction)
prec_before = precision_score(y_test, y_pred_raw, pos_label=1, zero_division=0)
prec_after  = precision_score(y_test, y_pred_iam, pos_label=1, zero_division=0)
rec_before  = recall_score(y_test, y_pred_raw,  pos_label=1, zero_division=0)
rec_after   = recall_score(y_test, y_pred_iam,  pos_label=1, zero_division=0)
f1_before   = f1_score(y_test, y_pred_raw,  pos_label=1, zero_division=0)
f1_after    = f1_score(y_test, y_pred_iam,  pos_label=1, zero_division=0)

summary = pd.DataFrame({
    "Metric":     ["Precision (Attack)", "Recall (Attack)", "F1 (Attack)"],
    "Before IAM": [round(prec_before, 4), round(rec_before, 4), round(f1_before, 4)],
    "After IAM":  [round(prec_after,  4), round(rec_after,  4), round(f1_after,  4)],
})
print("\n--- IAM Impact Summary ---")
print(summary.to_string(index=False))

# --- Step 6: Confusion Matrices — Before vs After IAM ---
fig, axes = plt.subplots(1, 2, figsize=(14, 5))

cm_before = confusion_matrix(y_test, y_pred_raw, labels=labels)
sns.heatmap(
    cm_before, annot=True, fmt='d', ax=axes[0],
    xticklabels=["Normal", "Attack"],
    yticklabels=["Normal", "Attack"],
    cmap="Oranges"
)
axes[0].set_title("Before IAM — Raw ML Predictions")
axes[0].set_xlabel("Predicted")
axes[0].set_ylabel("Actual")

cm_after = confusion_matrix(y_test, y_pred_iam, labels=labels)
sns.heatmap(
    cm_after, annot=True, fmt='d', ax=axes[1],
    xticklabels=["Normal", "Attack"],
    yticklabels=["Normal", "Attack"],
    cmap="Greens"
)
axes[1].set_title("After IAM — FP-Reduced Predictions")
axes[1].set_xlabel("Predicted")
axes[1].set_ylabel("Actual")

plt.suptitle("IAM False Positive Reduction: Confusion Matrix Comparison", fontsize=13, fontweight='bold')
plt.tight_layout()
plt.show()

# --- Step 7: IAM Trust Score vs Prediction Distribution ---
iam_analysis = pd.DataFrame({
    'trust_score':    trust_scores.values,
    'pred_before':    y_pred_raw,
    'pred_after':     y_pred_iam,
    'true_label':     y_test.values,
    'attack_prob':    y_prob_attack
})

plt.figure(figsize=(8, 5))
sns.boxplot(data=iam_analysis, x='trust_score', y='attack_prob', hue='true_label',
            palette={0: 'steelblue', 1: 'tomato'})
plt.title("Attack Probability by IAM Trust Score & True Label")
plt.xlabel("IAM Trust Score (0=LOW, 1=MEDIUM, 2=HIGH)")
plt.ylabel("Model's Attack Probability")
plt.legend(title="True Label", labels=["Normal (0)", "Attack (1)"])
plt.tight_layout()
plt.show()

print("\n" + "=" * 50)
print("PIPELINE COMPLETE")
print("=" * 50)
